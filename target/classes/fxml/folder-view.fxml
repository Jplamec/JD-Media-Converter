<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml" fx:controller="com.jdmedia.controller.FolderController" alignment="CENTER" spacing="20" styleClass="content-view"><children><Label fx:id="titleLabel" styleClass="view-title"/><Label text="%folder.hint" styleClass="view-subtitle"/><HBox alignment="CENTER" spacing="8"><TextField fx:id="folderField" prefWidth="580" promptText="%folder.path"/><Button text="%folder.folder" onAction="#chooseFolder"/><Button text="%folder.file" onAction="#chooseFile"/></HBox><HBox alignment="CENTER" spacing="10"><Button text="%back" onAction="#back"/><Button text="%folder.analyze" styleClass="primary-button" onAction="#continueFlow"/></HBox></children><padding><Insets top="40" right="30" bottom="40" left="30"/></padding></VBox>
