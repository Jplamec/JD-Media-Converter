<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml" fx:controller="com.jdmedia.controller.SettingsController" alignment="CENTER" spacing="16" styleClass="content-view"><children><Label text="%settings.title" styleClass="view-title"/><VBox alignment="CENTER" spacing="8" styleClass="ffmpeg-panel"><Label text="%settings.engine" styleClass="section-title"/><Label fx:id="ffmpegStatus"/><HBox alignment="CENTER" spacing="8"><Button text="%settings.check" onAction="#checkFfmpeg"/><Button text="%settings.download" styleClass="primary-button" onAction="#installFfmpeg"/></HBox><ProgressBar fx:id="downloadProgress" prefWidth="360"/><Label fx:id="downloadLabel" styleClass="hint-text"/></VBox><GridPane hgap="10" vgap="12" maxWidth="650" styleClass="settings-card"><columnConstraints><ColumnConstraints minWidth="200"/><ColumnConstraints hgrow="ALWAYS"/></columnConstraints><children><Label text="%settings.language" GridPane.rowIndex="0"/><ComboBox fx:id="languageBox" GridPane.columnIndex="1" GridPane.rowIndex="0"/><Label text="%settings.ffmpegPath" GridPane.rowIndex="1"/><TextField fx:id="ffmpegField" GridPane.columnIndex="1" GridPane.rowIndex="1"/><Label text="%settings.ffprobePath" GridPane.rowIndex="2"/><TextField fx:id="ffprobeField" GridPane.columnIndex="1" GridPane.rowIndex="2"/><Label text="%settings.movies" GridPane.rowIndex="3"/><TextField fx:id="moviesField" GridPane.columnIndex="1" GridPane.rowIndex="3"/><Label text="%settings.moviesOutput" GridPane.rowIndex="4"/><TextField fx:id="moviesOutputField" GridPane.columnIndex="1" GridPane.rowIndex="4"/><Label text="%settings.series" GridPane.rowIndex="5"/><TextField fx:id="seriesField" GridPane.columnIndex="1" GridPane.rowIndex="5"/><Label text="%settings.seriesOutput" GridPane.rowIndex="6"/><TextField fx:id="seriesOutputField" GridPane.columnIndex="1" GridPane.rowIndex="6"/></children></GridPane><HBox alignment="CENTER" spacing="10"><Button text="%home" onAction="#home"/><Button text="%save" styleClass="primary-button" onAction="#save"/></HBox></children></VBox>
