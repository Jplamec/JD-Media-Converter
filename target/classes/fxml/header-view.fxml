<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml" fx:controller="com.jdmedia.controller.HeaderController" styleClass="header-bar"><padding><Insets top="16" right="28" bottom="16" left="28"/></padding><center><VBox alignment="CENTER" spacing="3"><Label text="JD Media Converter" styleClass="header-title"/><Label text="%header.tagline" styleClass="header-subtitle"/><HBox alignment="CENTER" spacing="8"><Button text="%header.history" onAction="#openHistory" styleClass="header-button"/><Button text="%header.settings" onAction="#openSettings" styleClass="header-button"/></HBox></VBox></center><right><HBox alignment="CENTER_RIGHT" spacing="8"><VBox alignment="CENTER" spacing="2"><ComboBox fx:id="languageBox" prefWidth="70"/><Label text="%header.language" styleClass="header-language-label"/></VBox><Button text="?" onAction="#openHelp" styleClass="help-button"/></HBox></right></BorderPane>
