<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml" fx:controller="com.jdmedia.controller.ConversionController" alignment="CENTER" spacing="20" styleClass="content-view"><children><VBox alignment="CENTER" spacing="16" maxWidth="720" styleClass="conversion-card"><Label text="%conversion.title" styleClass="view-title"/><Label fx:id="currentFileLabel" wrapText="true" styleClass="view-subtitle"/><Label fx:id="encoderLabel" styleClass="hint-text"/><HBox alignment="CENTER" spacing="8"><TextField fx:id="destinationField" prefWidth="450" promptText="%conversion.destination"/><Button text="%conversion.browse" onAction="#chooseDestination"/></HBox><CheckBox fx:id="deleteOriginals" text="%conversion.deleteOriginals"/><Button fx:id="startButton" text="%conversion.start" styleClass="primary-button" onAction="#start"/><HBox alignment="CENTER" spacing="12"><ProgressBar fx:id="progressBar" prefWidth="520"/><Label fx:id="percentLabel" styleClass="progress-percent"/></HBox><Label text="%conversion.safety" styleClass="hint-text"/><Button fx:id="cancelButton" text="%conversion.cancel" onAction="#cancel"/></VBox></children></VBox>
