<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml" fx:controller="com.jdmedia.controller.ConversionController" alignment="CENTER" spacing="20" styleClass="content-view"><children><VBox alignment="CENTER" spacing="16" maxWidth="720" styleClass="conversion-card"><Label text="Conversión" styleClass="view-title"/><Label fx:id="currentFileLabel" wrapText="true" styleClass="view-subtitle"/><Label fx:id="encoderLabel" styleClass="hint-text"/><HBox alignment="CENTER" spacing="8"><TextField fx:id="destinationField" prefWidth="450" promptText="Carpeta de destino"/><Button text="Examinar…" onAction="#chooseDestination"/></HBox><CheckBox fx:id="deleteOriginals" text="Eliminar archivos originales tras comprobar que la conversión fue correcta"/><Button fx:id="startButton" text="Iniciar conversión" styleClass="primary-button" onAction="#start"/><HBox alignment="CENTER" spacing="12"><ProgressBar fx:id="progressBar" prefWidth="520"/><Label fx:id="percentLabel" styleClass="progress-percent"/></HBox><Label text="Los originales nunca se borran si FFmpeg falla o se cancela." styleClass="hint-text"/><Button fx:id="cancelButton" text="Cancelar" onAction="#cancel"/></VBox></children></VBox>
